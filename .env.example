# --- Required ---

# Secret used by Better Auth for session signing. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Master key for AES-256-GCM encryption of stored provider API keys.
# Generate with:
#   openssl rand -hex 32
ENCRYPTION_KEY=

# --- Optional ---

# Public URL of this instance (needed behind a reverse proxy).
BETTER_AUTH_URL=http://localhost:3000

# SQLite database location (defaults to ./data/ctxai.db).
# DATABASE_PATH=./data/ctxai.db

# Directory where generated assets are stored (defaults to ./data/assets).
# ASSETS_DIR=./data/assets
